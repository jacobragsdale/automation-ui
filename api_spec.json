  "components": {
    "schemas": {
      "ColorRequest": {
        "properties": {
          "hsv": {
            "prefixItems": [
              {
                "type": "integer",
                "maximum": 360,
                "minimum": 0
              },
              {
                "type": "integer",
                "maximum": 100,
                "minimum": 0
              },
              {
                "type": "integer",
                "maximum": 100,
                "minimum": 0
              }
            ],
            "type": "array",
            "maxItems": 3,
            "minItems": 3,
            "title": "Hsv"
          }
        },
        "additionalProperties": false,
        "type": "object",
        "required": [
          "hsv"
        ],
        "title": "ColorRequest"
      },
      "DenylistAddRequest": {
        "properties": {
          "domain": {
            "type": "string",
            "minLength": 1,
            "title": "Domain"
          }
        },
        "additionalProperties": false,
        "type": "object",
        "required": [
          "domain"
        ],
        "title": "DenylistAddRequest"
      },
      "FocusSessionRequest": {
        "properties": {
          "duration_minutes": {
            "type": "integer",
            "maximum": 1440,
            "minimum": 5,
            "title": "Duration Minutes",
            "default": 60
          },
          "domains": {
            "items": {
              "type": "string"
            },
            "type": "array",
            "title": "Domains"
          },
          "categoryIds": {
            "items": {
              "type": "string"
            },
            "type": "array",
            "title": "Categoryids"
          },
          "serviceIds": {
            "items": {
              "type": "string"
            },
            "type": "array",
            "title": "Serviceids"
          },
          "safeSearch": {
            "type": "boolean",
            "title": "Safesearch",
            "default": true
          },
          "youtubeRestrictedMode": {
            "type": "boolean",
            "title": "Youtuberestrictedmode",
            "default": true
          },
          "blockBypass": {
            "type": "boolean",
            "title": "Blockbypass",
            "default": true
